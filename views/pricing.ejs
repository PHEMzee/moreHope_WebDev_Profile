<%- include("partials/header") %>

<section class="pricing-hero">
  <div class="container">
    <div class="pricing-hero-inner">
      <div>
        <p class="eyebrow">Pricing Plans</p>
        <h1>Flexible packages for modern web projects</h1>
        <p class="pricing-intro">
          Choose the plan that fits your business goals. Each package is built
          for quality, performance, and a polished user experience.
        </p>
      </div>
      <a class="btn btn-primary pricing-hero-button" href="#plans"
        >View Plans</a
      >
    </div>
  </div>
</section>

<section class="pricing-plans" id="plans">
  <div class="container">
    <div class="section-heading">
      <h2>Choose your package</h2>
      <p>
        Transparent pricing for professional portfolio and business websites.
      </p>
    </div>

    <div class="row gy-4">
      <div class="col-md-4">
        <article class="pricing-card">
          <span class="pricing-label">Starter</span>
          <h3>Essential Web Presence</h3>
          <p class="pricing-value">$450</p>
          <ul class="pricing-features">
            <li>Responsive 3-page website</li>
            <li>Modern layout and branding</li>
            <li>Contact form integration</li>
            <li>Basic SEO setup</li>
          </ul>
          <a
            class="btn btn-outline-primary pricing-action"
            href="/pricing#contact"
            >Start Now</a
          >
        </article>
      </div>

      <div class="col-md-4">
        <article class="pricing-card pricing-card-featured">
          <span class="pricing-label">Professional</span>
          <h3>Growth-ready Website</h3>
          <p class="pricing-value">$850</p>
          <ul class="pricing-features">
            <li>Up to 6 pages</li>
            <li>Portfolio or service showcase</li>
            <li>Performance optimization</li>
            <li>CMS-ready or dynamic content</li>
          </ul>
          <a class="btn btn-primary pricing-action" href="/pricing#contact"
            >Get Started</a
          >
        </article>
      </div>

      <div class="col-md-4">
        <article class="pricing-card">
          <span class="pricing-label">Premium</span>
          <h3>Full-Featured Experience</h3>
          <p class="pricing-value">$1,450</p>
          <ul class="pricing-features">
            <li>Advanced UI/UX design</li>
            <li>Custom animations and interactions</li>
            <li>Deployment and launch support</li>
            <li>Post-launch review & updates</li>
          </ul>
          <a
            class="btn btn-outline-primary pricing-action"
            href="/pricing#contact"
            >Book a Call</a
          >
        </article>
      </div>
    </div>

    <div class="pricing-details">
      <div class="pricing-detail-card">
        <h4>What you get</h4>
        <p>
          Each plan includes responsive design, mobile-first development,
          accessibility best practices, and clean, maintainable code.
        </p>
      </div>
      <div class="pricing-detail-card">
        <h4>How it works</h4>
        <p>
          Reach out with your project goals, and I’ll provide a tailored
          timeline, clear milestones, and a professional website built to grow
          with you.
        </p>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
