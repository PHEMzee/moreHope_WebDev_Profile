<%- include("partials/header") %>

<section class="container py-2">
  <div class="row justify-content-center">
    <div class="col-xl-10">
      <div class="card shadow-sm overflow-hidden border-0">
        <div class="row g-0">
          <div
            class="col-lg-5 bg-primary text-white p-5 d-flex flex-column justify-content-center">
            <span class="badge bg-light text-primary mb-3">moreHOPE</span>
            <h1 class="h2 mb-3">Welcome back</h1>
            <p class="mb-4">
              Sign in to continue building your portfolio and keep your profile
              up to date.
            </p>
            <ul class="list-unstyled mb-0">
              <li class="mb-2">
                <i class="fas fa-check-circle me-2"></i>Clean, responsive layout
              </li>
              <li class="mb-2">
                <i class="fas fa-check-circle me-2"></i>Fast form experience
              </li>
              <li>
                <i class="fas fa-check-circle me-2"></i>Friendly login flow
              </li>
            </ul>
          </div>
          <div class="col-lg-7 p-4 p-md-4">
            <div class="mb-4">
              <h2 class="h4 mb-2">Sign in to your account</h2>
              <p class="text-muted">
                Use your email and password to access the dashboard.
              </p>
            </div>

            <form action="/login" method="post" class="mb-4">
              <div class="mb-3">
                <label for="email" class="form-label">Email address</label>
                <input
                  type="email"
                  class="form-control"
                  id="email"
                  name="email"
                  placeholder="you@example.com"
                  required />
              </div>
              <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input
                  type="password"
                  class="form-control"
                  id="password"
                  name="password"
                  placeholder="••••••••"
                  required />
              </div>
              <div
                class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    id="remember"
                    name="remember" />
                  <label class="form-check-label" for="remember"
                    >Remember me</label
                  >
                </div>
                <a href="#" class="small">Forgot password?</a>
              </div>
              <button type="submit" class="btn btn-primary w-100">Login</button>
            </form>

            <div class="text-center text-muted mb-3">
              New here? Create an account below
            </div>

            <form action="/signup" method="post">
              <div class="mb-3">
                <label for="newEmail" class="form-label">Email address</label>
                <input
                  type="email"
                  class="form-control"
                  id="newEmail"
                  name="email"
                  placeholder="you@example.com"
                  required />
              </div>
              <div class="mb-3">
                <label for="newPassword" class="form-label">Password</label>
                <input
                  type="password"
                  class="form-control"
                  id="newPassword"
                  name="password"
                  placeholder="Create a password"
                  required />
              </div>
              <div class="mb-3">
                <label for="confirmPassword" class="form-label"
                  >Confirm password</label
                >
                <input
                  type="password"
                  class="form-control"
                  id="confirmPassword"
                  name="confirmPassword"
                  placeholder="Repeat password"
                  required />
              </div>
              <button type="submit" class="btn btn-outline-primary w-100">
                Create account
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
